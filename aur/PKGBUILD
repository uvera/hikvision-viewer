# Maintainer: Your Name <you@example.com>
#
# GitHub releases: run scripts/release-github-aur.sh from the upstream repo to set url=,
# source= (tag archive), and sha256sums, and regenerate .SRCINFO. Copy PKGBUILD + .SRCINFO
# into your AUR clone and push to aur.archlinux.org.
#
# Local tarball (not GitHub): see scripts/package-release.sh — parent dir must be $pkgname-$pkgver.

pkgname=hikvision-viewer
pkgver=0.1.0
pkgrel=2
pkgdesc="PyQt6 multi-stream RTSP viewer for IP cameras"
arch=('any')
url='https://github.com/USERNAME/hikvision-viewer'
license=('MIT')
depends=('python' 'mpv' 'python-pyqt6' 'python-pyyaml' 'python-cryptography' 'python-keyring' 'python-dotenv' 'python-mpv')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
install=hikvision-viewer.install
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('d38d960e00b07abd0f03b8c6ae2c2ce2ffcba22a8b7e7e28f9daa0a070978184')

build() {
  cd "${pkgname}-${pkgver}"
  python -m build --wheel --no-isolation
}

package() {
  cd "${pkgname}-${pkgver}"
  python -m installer --destdir="$pkgdir" --prefix=/usr dist/*.whl
  install -Dm644 config.example.yaml -t "${pkgdir}/usr/share/doc/${pkgname}/"
}
